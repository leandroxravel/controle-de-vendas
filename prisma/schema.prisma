datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  VENDEDOR
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String?
  role      Role     @default(VENDEDOR)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  vendas    Venda[]
}

model Venda {
  id                    String    @id @default(uuid())
  chassi                String    @unique
  nomeCliente           String
  numeroPedidoFabrica   String
  modelo                String
  versao                String
  cor                   String
  anoModelo             Int
  marca                 String
  loja                  String
  temUsado              Boolean   @default(false)
  temFinanciamento      Boolean   @default(false)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  userId                String
  user                  User      @relation(fields: [userId], references: [id])
}