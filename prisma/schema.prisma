generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoleName {
  ADMIN
  SALESPERSON
}

enum VehicleStatus {
  AVAILABLE
  SOLD
  RESERVED
}

model Role {
  id    String   @id @default(uuid())
  name  RoleName @unique
  users User[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id       String  @id @default(uuid())
  email    String  @unique
  password String
  name     String
  roleId   String
  storeId  String? // Optional: an admin might not be tied to a specific store

  role  Role   @relation(fields: [roleId], references: [id])
  store Store? @relation(fields: [storeId], references: [id])

  sales Sale[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Store {
  id      String @id @default(uuid())
  name    String @unique
  address String?
  phone   String?

  users    User[]
  vehicles Vehicle[]
  sales    Sale[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VehicleMake {
  id   String @id @default(uuid())
  name String @unique

  vehicles Vehicle[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Vehicle {
  id          String        @id @default(uuid())
  makeId      String
  model       String
  year        Int
  color       String
  vin         String        @unique // Vehicle Identification Number
  price       Decimal       @db.Decimal(10, 2)
  isUsed      Boolean
  stockNumber String        @unique // Unique identifier for the vehicle in inventory
  status      VehicleStatus @default(AVAILABLE)
  storeId     String

  make  VehicleMake @relation(fields: [makeId], references: [id])
  store Store       @relation(fields: [storeId], references: [id])

  sale Sale? // One-to-one relationship: a vehicle can be part of one sale

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([storeId, stockNumber]) // Ensure stock number is unique per store
}

model Sale {
  id            String    @id @default(uuid())
  vehicleId     String    @unique // Each vehicle can only be sold once
  sellerId      String
  storeId       String
  saleDate      DateTime  @default(now())
  finalPrice    Decimal   @db.Decimal(10, 2)
  isFinanced    Boolean
  customerName  String
  customerEmail String?
  customerPhone String?

  vehicle Vehicle @relation(fields: [vehicleId], references: [id])
  seller  User    @relation(fields: [sellerId], references: [id])
  store   Store   @relation(fields: [storeId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}